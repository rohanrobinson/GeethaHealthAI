# Local dev — Postgres running on your machine (e.g. docker compose up -d postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/familycare

# Docker — uncomment when using `docker compose up` for the api service
# DATABASE_URL=postgresql://postgres:postgres@postgres:5432/familycare

SECRET_KEY=change-me-to-a-long-random-string
PORT=8000
